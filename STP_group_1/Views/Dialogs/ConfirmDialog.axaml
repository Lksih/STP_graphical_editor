<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:STP_group_1.ViewModels.Dialogs"
        x:Class="STP_group_1.Views.Dialogs.ConfirmDialog"
        x:DataType="vm:ConfirmDialogViewModel"
        Width="420" Height="160"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
  <DockPanel Margin="16">
    <TextBlock DockPanel.Dock="Top"
               TextWrapping="Wrap"
               Text="{Binding Message}" />
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
      <Button Content="Отмена" IsCancel="True" Command="{Binding CancelCommand}" />
      <Button Content="Да" IsDefault="True" Command="{Binding OkCommand}" />
    </StackPanel>
  </DockPanel>
</Window>


