<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="STP_group_1.App"
             xmlns:vm="using:STP_group_1.ViewModels"
             xmlns:views="using:STP_group_1.Views"
             xmlns:dialogs="using:STP_group_1.Views.Dialogs"
             RequestedThemeVariant="Default">

	<Application.DataTemplates>
		<DataTemplate DataType="{x:Type vm:MainWindowViewModel}">
			<views:MainWindow/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type dialogs:ConfirmDialogViewModel}">
			<dialogs:ConfirmDialog/>
		</DataTemplate>

		<DataTemplate DataType="{x:Type dialogs:NewCanvasDialogViewModel}">
			<dialogs:NewCanvasDialog/>
		</DataTemplate>
	</Application.DataTemplates>

	<Application.Styles>
		<FluentTheme />
	</Application.Styles>
</Application>
